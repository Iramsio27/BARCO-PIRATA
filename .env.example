# ──────────────────────────────────────────────────────────────────────────
#  Barco Pirata – Variables de entorno
# ──────────────────────────────────────────────────────────────────────────
#  Copia este archivo como `.env.local` y completa los valores.
#  NUNCA commits el .env.local con credenciales reales.
#  Solo variables con prefijo VITE_ son expuestas al cliente.
# ──────────────────────────────────────────────────────────────────────────

# ─── Supabase (base de datos + auth) ───────────────────────────────────────
# URL del proyecto: https://<project-id>.supabase.co
VITE_SUPABASE_URL=https://your-project-id.supabase.co
# Clave pública (anon key). Es segura para el frontend cuando hay RLS activado.
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# ─── Stripe (pasarela de pagos) ────────────────────────────────────────────
# Publishable key (pk_test_... o pk_live_...).
# La secret key JAMÁS debe estar aquí; vive en las Edge Functions.
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_your-publishable-key

# ─── API (opcional) ────────────────────────────────────────────────────────
# Si usas un backend propio además de Supabase Edge Functions.
VITE_API_URL=/api

# ─── App config ────────────────────────────────────────────────────────────
VITE_APP_ENV=development
